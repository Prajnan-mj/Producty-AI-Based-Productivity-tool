# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/producty_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# Google OAuth (from console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── LLM provider ────────────────────────────────────────────────
# "nvidia" (default), "gemini", or "mock" (no API calls, for UI testing)
LLM_PROVIDER=nvidia

# NVIDIA NIM (https://build.nvidia.com — key starts with "nvapi-")
NVIDIA_API_KEY=nvapi-your_key_here
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Gemini (only used if LLM_PROVIDER=gemini; key starts with "AIzaSy")
GEMINI_API_KEY=
GEMINI_API_KEYS=

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Environment ─────────────────────────────────────────────────
# DEBUG=true enables API docs, permissive localhost CORS, and insecure-transport
# OAuth. Set DEBUG=false in production (then SECRET_KEY + CORS_ALLOW_ORIGINS are
# enforced at startup).
DEBUG=true

# Frontend origin used for the OAuth redirect and CORS.
FRONTEND_URL=http://localhost:5173
# Production CORS allowlist (comma-separated). Used only when DEBUG=false.
CORS_ALLOW_ORIGINS=
